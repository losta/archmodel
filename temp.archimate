              <child xsi:type="archimate:Note" id="id-f2550468c8454ee2bc09e4874cc4fb1f" textAlignment="1">
                <bounds x="528" y="336" width="151" height="60"/>
                <content>Ask FXPH about currency limits or facilities on the currency accounts? &#xD;
&#xD;
</content>
              </child>
