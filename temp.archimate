                    <bounds x="12" y="300" width="181" height="25"/>
                  </child>
                  <child xsi:type="archimate:DiagramObject" id="id-250187c5ccaa4a2b9331c5fc0bcd2231" font="1|Arial|7.8|0|WINDOWS|1|-13|0|0|0|400|0|0|0|0|3|2|1|34|Arial" fillColor="#e7e6e6" archimateElement="id-a486b289e3214e8398ff9fd99df42738">
                    <bounds x="12" y="264" width="181" height="25"/>
                  </child>
                  <child xsi:type="archimate:Note" id="id-219488bee3074ad49de2017cebe5130c" textAlignment="1">
                    <bounds x="19" y="24" width="168" height="229"/>
                    <content>TTS currently relies on Markets stakeholders to log onto the JSE Broker Dealing Application system to verify the brokers' net purchases and set it off against their net sales to establish the risk associated with their settlements. Ideally, this logic should be replaced with sweeping rules on the brokers' current accounts. This is to be tested for go-live 17 Nov 2025. </content>
                  </child>
                </child>
                <child xsi:type="archimate:DiagramObject" id="id-ebb8c735987d41c780b8d311721f1e51" font="1|Arial|9.0|0|WINDOWS|1|-15|0|0|0|400|0|0|0|0|3|2|1|34|Arial" fillColor="#ffffff" archimateElement="id-b0d0beb9cad145ab9a7422536fc56238">
                  <bounds x="13" y="504" width="238" height="276"/>
                </child>
                <child xsi:type="archimate:DiagramObject" id="id-a9e0f5e3a6ca4d5db09c4fab742f1671" font="1|Arial|9.0|0|WINDOWS|1|-15|0|0|0|400|0|0|0|0|3|2|1|34|Arial" fillColor="#ffffff" archimateElement="id-fe1ce747a69449af953fe21354ed07f5">
                  <bounds x="13" y="828" width="238" height="109"/>
                  <child xsi:type="archimate:Note" id="id-545cb2ad6a11434bb02ec160282a4a32" textAlignment="1">
                    <bounds x="12" y="36" width="217" height="61"/>
                    <content>IBD Only - Loan Origination and Risk Participations here could trigger TTS services. </content>
