    <element xsi:type="archimate:Capability" name="MNC Strategy &amp; Solutioning" id="id-d506d23b32aa4398ba82c28c7e63a9a0"/>
    <element xsi:type="archimate:Capability" name="Market Trade Participants / Facilitator (Komgo, Mitigram, Finverity, Taulia, Addendum) Engagements" id="id-dc8e65cdf0764249aebd0d9eb27567ef"/>
  </folder>
  <folder name="Business" id="id-44a56d88e95342c09fbbe872ff70d250" type="business">
    <folder name="Actors" id="id-10f08f6e73c24841be219738387eeac3">
      <element xsi:type="archimate:BusinessActor" name="Settlement Bank (Commercial Bank) 1" id="id-019ea200c3cc4a19a293f4c2e1fe46c9"/>
      <element xsi:type="archimate:BusinessActor" name="Account Product Managers (2 people)" id="id-0203627de07a47a1963bca31352c9a5a"/>
      <element xsi:type="archimate:BusinessActor" name="FX and Cross Border Product Head" id="id-028021891bb94b2e99f8690505c5b5b3"/>
      <element xsi:type="archimate:BusinessActor" name="CSD Participant 3" id="id-037633e1caad44c2ab6112c9db5ceaa5"/>
      <element xsi:type="archimate:BusinessActor" name="Transactor Team Lead (what area?) - Ben" id="id-08a357a3217844ccb55ff5ca20b4b5de"/>
      <element xsi:type="archimate:BusinessActor" name="Technology Architect" id="id-099d1736a80e45af8e5f4842c195a4fc"/>
      <element xsi:type="archimate:BusinessActor" name="FirstRand SWIFT Financial Gateway - S&amp;S Team" id="id-0d0741b6df59490faa3371cbdfcd9c2c"/>
      <element xsi:type="archimate:BusinessActor" name="Personal Assistant" id="id-0fc111ad571d4fbc9101173d11dfbdc3"/>
      <element xsi:type="archimate:BusinessActor" name="TWC Product Manager" id="id-116e52ccc7e346508e1c5f62f799dc50"/>
      <element xsi:type="archimate:BusinessActor" name="Importer" id="id-162d6e97e80242f5ac584f63c14e9d99"/>
