              <child xsi:type="archimate:Note" id="id-2f8edef0e0c6492ca5d0bad9e14fcf6c" textAlignment="1">
                <bounds x="264" y="144" width="421" height="43"/>
                <content>Interest receivable from Treasury - should this be calculated by Treasury and department is informed? Or do both sides calculate and reconcile? </content>
              </child>
              <child xsi:type="archimate:DiagramObject" id="id-c1e880cb06e34918b40250acb97854e9" targetConnections="id-4ef95bf23a9841c08c5d19f93aa1281a id-47ae67488eb0429e9be59eec0b69cf9e id-60b1af1d142e46a794615213ba541eb7" archimateElement="id-f68eaf8296f54905bf4992cc11a93d3c">
