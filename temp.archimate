                  <child xsi:type="archimate:Note" id="id-87b4bd03ebf946b99725a1af531cb5df" textAlignment="1">
                    <bounds x="12" y="24" width="168" height="73"/>
                    <content>Ashburton and Fund Managers - these settlements could also impact these brokers. </content>
                  </child>
                </child>
                <child xsi:type="archimate:DiagramObject" id="id-7af7dc56facb4192a3cbc4e037cb2713" font="1|Arial|9.0|0|WINDOWS|1|-15|0|0|0|400|0|0|0|0|3|2|1|34|Arial" fillColor="#ffffff" archimateElement="id-3d23b28398c14fd0a196bafe3ceb5a09">
