      <element xsi:type="archimate:BusinessInterface" name="Secure File Transfer Protocol (MFT)" id="id-163f074518f64cf9b5126c5378feed8d"/>
      <element xsi:type="archimate:BusinessInterface" name="Letter of Credit Application (eTradePort - TIPlus front-end)" id="id-16ac35858f674928b2809ba0035320a3"/>
      <element xsi:type="archimate:BusinessInterface" name="Factoring" id="id-19d3f96ff0e845269356f2d36884ebd1"/>
      <element xsi:type="archimate:BusinessInterface" name="3rd Party / Fund Managers  - Property Guarantees (3PIM)" id="id-1b8ca894f5ca4851b5a88df23a6f181b"/>
      <element xsi:type="archimate:BusinessInterface" name="SmartTill" id="id-1bac1577dc43496a9764f276db379aa0"/>
