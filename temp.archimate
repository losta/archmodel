    <element xsi:type="archimate:Capability" name="Business Analysis" id="id-1766a96f5ce548f58efff42b83a035be"/>
    <element xsi:type="archimate:Capability" name="TWC Research &amp; Reporting" id="id-3a321a32dce748798422167e766a8c9b"/>
    <element xsi:type="archimate:Capability" name="TWC Transaction Management" id="id-4f7c57ad3d224ff5a0dd2aea4047d61d"/>
    <element xsi:type="archimate:Capability" name="Client Needs Analysis &amp; Product Assessment" id="id-54572b1909ea41baaeb01075d7a03521"/>
    <element xsi:type="archimate:Capability" name="Loans and Deposits" id="id-653abb9ee3d847c193fe988e01bc603b"/>
    <element xsi:type="archimate:Capability" name="Trade &amp; Working Capital Operations: Product Specific Fulfilment" id="id-664ecad6b7e04b8ebfb63ae04dc6db0a"/>
    <element xsi:type="archimate:Capability" name="Regulation and Compliance" id="id-6c2ffcbeef7942bab91ffaa996207e09"/>
    <element xsi:type="archimate:Capability" name="Bank Portfolio and Treasury" id="id-758931f5fd3c4adc80ca26d818a31ca3"/>
    <element xsi:type="archimate:Capability" name="Product Design &amp; Development, Governance &amp; Approvals" id="id-7dbabf8c9a1245d48892d08f9c99521d"/>
    <element xsi:type="archimate:Capability" name="Strategy Compilation" id="id-87355a18ad0a479e95a2154cef75f2b9"/>
