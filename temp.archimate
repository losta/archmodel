      <element xsi:type="archimate:ValueStream" name="Correspondent Banking Onboarding" id="id-e5a85a723896448da49ff0a4b07db9f2"/>
      <element xsi:type="archimate:ValueStream" name="STCF Business Development" id="id-e7024a6b7ef2427e89ee64a061df8a20"/>
      <element xsi:type="archimate:ValueStream" name="Supply Chain Finance Onboarding" id="id-eb436473bef94a9bb3d177b56c1f8db7"/>
      <element xsi:type="archimate:ValueStream" name="Trade Servicing Operations &amp; Execution" id="id-ede0d565b92c4e408d9658c0d93ba12c"/>
      <element xsi:type="archimate:ValueStream" name="TWC Servicing Operations &amp; Execution" id="id-f08e1ba18b3a46e1916f0f3683b83357"/>
      <element xsi:type="archimate:ValueStream" name="Working Capital Onboarding" id="id-f3367eca238c448086e5fd07375d9277"/>
      <element xsi:type="archimate:ValueStream" name="Assets &amp; Liability Management (copy)" id="id-f3a0c0adb2544196b7f68aaf1dd3bb9b">
        <documentation>Place assets and liabilities with Treasury</documentation>
      </element>
      <element xsi:type="archimate:ValueStream" name="Payments Onboarding" id="id-f4d61724bd914a718f65bb3c10a95cc8"/>
      <element xsi:type="archimate:ValueStream" name="Correspondent Banking Operations - Monitoring, Exception &amp; Query Management" id="id-faa676420c2e468a91a64566b5666714"/>
      <element xsi:type="archimate:ValueStream" name="Assets &amp; Liability Management" id="id-fb855c83f6384d2f953e0edc996baae5">
        <documentation>Place assets and liabilities with Treasury</documentation>
      </element>
      <element xsi:type="archimate:ValueStream" name="Collections Business Development" id="id-fc466e337738437cbbe194b106f2df58"/>
      <element xsi:type="archimate:ValueStream" name="Corporate Treasury (copy)" id="id-fc5ba068b3bb4a428c467b947e4f4525"/>
      <element xsi:type="archimate:ValueStream" name="STCF Onboarding" id="id-fca0966aca724ca3b181ebaf28bbbf6d"/>
      <element xsi:type="archimate:ValueStream" name="TWC Onboarding" id="id-ff7b8e898e4e49b08f2306584e819373"/>
    </folder>
    <folder name="Capabilities" id="id-721d81149ec0474d91ef2a1a940d9e12">
      <element xsi:type="archimate:Capability" name="Collateral Administration" id="id-0246d5de774d4ddf9ed6b9d81a1890eb">
        <documentation>Brings together a number of general back office services that provide cross product support not directly matched to the other Business Domains in this Business Area. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Payments" id="id-088bcf8fe01d44538976f53c3b73f63e">
        <documentation>Groups the Service Domains supporting payment transactions, including the various connections to payment networks, central cash management and check processing. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Building Equipment and Facilities" id="id-0f8d8cafb822427fabf7dfc2ee5301ae">
        <documentation>Covers all activities associated with the acquisition, administration, operation and maintenance of buildings and non-IT equipment (this can include fleet/transport facilities when appropriate). &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Account Management" id="id-1098da42840540b1a90d10486fe2dfaa">
        <documentation>Groups together a range of Service Domains that support account and account related services for cash/currency and reward point accounts. It includes account reconciliation, accounts receivable processing and some broader consolidated position management and fraud detection facilities. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="In-Country Client Sales Engagement" id="id-116a77c0a33c44b385ea9597c95f5402"/>
      <element xsi:type="archimate:Capability" name="Loans and Deposits" id="id-224f55e4d9ea41c280a965954fd0e0ad">
        <documentation>Contains the Service Domains associated with the fulfillment of the main Loan and Deposit products, it includes the core Current Account or DDA product. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Business Analysis" id="id-23bfae2b607746f1ad33a353e7d29f85">
        <documentation>Consolidates the range of enterprise and divisional performance analysis activities covering general areas such as customer segment and product profitability and more targeted/specialized considerations such as channel. branch portfolio and contribution analysis. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Human Resource Management" id="id-23fd3bffb6c74903949fbfe8c7525e32">
        <documentation>Brings together the wide range of human resource management functions including recruitment, training, assessment and allocation tasks and the range of employee support functions including payroll &amp; benefits, travel and expenses and employee access controls and authorities.&#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Profile Verification Services" id="id-2589117c19c54acba6320f9dfda12bd3"/>
      <element xsi:type="archimate:Capability" name="Enterprise Architecture Management" id="id-30188dca90e24d59bbb9499c66aa8f65"/>
      <element xsi:type="archimate:Capability" name="Bank Portfolio and Treasury" id="id-35b9b8940b844b90b9a6c88a43ca179a">
        <documentation>Draws together the Group Treasury and overall bank portfolio management activities as might be overseen by the bank's asset and liability committee (ALCO) or equivalent policy function. It includes some functions typically related to managing the balance sheet (repos and securitization).&#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Market Data" id="id-3c0fa90c8f7b4e71ad9bf323c9866890">
        <documentation>Covers access to &amp; the internal distribution of the different market research, analysis, news, quote and pricing feeds. This includes the specialized feeds that support trading activity, more general market research and analysis and access to any global directories and information standards.</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Wholesale Trading" id="id-3d23b28398c14fd0a196bafe3ceb5a09">
        <documentation>Covers broad range of front and middle office wholesale trading activities across all major instrument categories (FX/money market, equities, securities, commodities, derivatives). It also covers basic primary market functions such as equity/debt issuance and trading. &#xD;
&#xD;
TTS offers Corporate &amp; Institutional Loans &amp; Deposits Client Dealing via the Global Markets Dealer Desks. FX deals required for TWC currency loans and deposits are also booked via the GM FX markets desks (to confirm whether it's only the funding leg). STCF requires hedging which are serviced by all these wholesale trading activities. </documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Document Management &amp; Archive" id="id-41578793b97d41c18e7106e2604f3e01">
        <documentation>Provides central document management capabilities - covering bulk mailing (in and out bound) general document scanning, indexing and retrieval services and any physical and electronic distribution and archiving capabilities. It assumes some level of centralization of document handling and digitization for streamlining of production operations. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Market Operations" id="id-43d2dc42c1cd410f94ce462411bc3401">
        <documentation>Combines various back office and support functions for wholesale trading including clearing and settlement and custodial services. It includes trade reporting, valuations and fund administration activities. &#xD;
&#xD;
TTS Impact: Global Markets Only - However, STCF requires hedges as part of their product offerings, so will trigger Markets' processes that then pass margin/interest back to them for settlement to client loan. &#xD;
Also Custodial Corporate Action processes trigger payment instructions that come from the Market through the Financial Gateway for processing, but could also be recipients of those settlements for onward distribution. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Customer Management" id="id-4599f13e35d241eeb8d36ef3794e3735">
        <documentation>Covers the main aspects of customer relationship management including product matching/eligibility, agreements, behavioral analysis, relationship development and account recovery. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="External Agency" id="id-461f6d1171644df38ee2c47628f9e866">
        <documentation>Brings together Service Domains that cover the relationship and agreement details for the range of external business relationships.</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Trade Banking" id="id-5752577231ca4088a53d6f6688011843">
        <documentation>Brings together a broad range of trade banking product and service fulfillment Service Domains covering trade finance and the many different cash management services that might be offered.  &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Internal Product &amp; Service Eligibility Assessment" id="id-64bf69cc7442486c8937b5ef7af4a0b9"/>
      <element xsi:type="archimate:Capability" name="Operational Services" id="id-66f7191434314b7eaf380f74f4734e3c">
        <documentation>Provides the fairly narrow grouping of Service Domains that support the management allocation and recovery of collateral against a customer.&#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Product Portfolio Development" id="id-68caaa23e04347e1b0c7fa88c3d40733"/>
      <element xsi:type="archimate:Capability" name="Non-IT and Non-HR Enterprise Services" id="id-71da6edf9e62490eace83b62a85a7482">
        <documentation>Brings together a collection of general non-IT related support services including internal audit, security and legal advisory services, supplier management and procurement, fixed asset register and company billing and payments. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Marketing" id="id-8289a266b7da420e898e043ef4f0f810">
        <documentation>Covers new business development activities including prospect and internal campaign design and development, customer surveys and advertising. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Information Management" id="id-8a39108109334a05b48a5c8f033f4b2a"/>
      <element xsi:type="archimate:Capability" name="Product Management" id="id-8fc6bec41d834a0cb04a5186d076e0bf">
        <documentation>Includes the Service Domains that define and are referenced for all types of internal product information. This includes product designs and specifications, allowed product combinations, eligibility and pricing terms to apply and providing access to associating training and quality assurance. </documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Strategic Planning" id="id-916ae93d5c4e4352b8f783b55b98ad94"/>
      <element xsi:type="archimate:Capability" name="Business Direction" id="id-93e1119b640043b38c8adca062e04fa1">
        <documentation>Contains the enterprise's executive functions (policies, strategy and direction) and some enterprise wide tasks such as business architecture and continuity planning.&#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Consumer Services" id="id-97da68eaafd244b09819a08d99a795c8">
        <documentation>Brings together a number of services typically provided to consumer customers such as remittances, currency exchange, tax, investment and 3rd party product offerings (e.g. insurance). It also handles any consumer tax reporting obligations. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Market Research &amp; Opportunity Identification" id="id-9c69baf3c9034148b14d2734c656178d"/>
      <element xsi:type="archimate:Capability" name="Partner Management" id="id-a4d9f9c2d15f4e3884897261d60b932e"/>
      <element xsi:type="archimate:Capability" name="Finance" id="id-ac1c817ed6f44c8d9bf38f191d939a86">
        <documentation>Covers the central financial control and reporting activities of the enterprise including division/unit budget negotiations, reporting and financial audit and the assembly and reporting of the financial statements. It also includes enterprise/legal entity tax handling. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Cards" id="id-b0d0beb9cad145ab9a7422536fc56238">
        <documentation>Contains the fulfilment Service Domains for all cards related products (Credit &amp; Charge). Note that debit cards associated with a current account may leverage some of these capabilities &amp; that many merchant related activities not fully represented at this stage. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Business Command and Control" id="id-b8553856205b4fb986ab219a88f7a109">
        <documentation>Contains the range of capabilities associated with the organizational command and control structure of the enterprise. Typically these Service Domains may be repeated and/or may be structured to handle multiple Lines of Business, Legal Entities and/or Business Units (profit/cost centers) as necessary to reflect the specific structure of the enterprise. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Sales Plan Management" id="id-b8d12fb5631e4f4288659a7563efd9fc"/>
      <element xsi:type="archimate:Capability" name="Party (iCustomer / Client Groups)" id="id-bbb38c22bfb54c87b6944b8e7a17ab3f">
        <documentation>Covers the different party/customer reference information that is maintained by the bank for its institutional, corporate and consumer customers.   </documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Product Governance &amp; Approvals" id="id-c344bc4d0aa04bca816f70b08a867e6b"/>
      <element xsi:type="archimate:Capability" name="Corporate Relations" id="id-c986cfe3cfdb45cc84a5bda8faaff057">
        <documentation>Contains Service Domains that handle general corporate communications (with interested parties including investors) and the relationships with key legal and regulatory authorities. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Channel Specific" id="id-cf095017be5d4301bcc4cfe8ad02cc98">
        <documentation>Includes a mixture of service domains that provide the management, configuration and operation of the different channels used by customers to access the products and services of the bank. It includes activities associated with the physical branch network and the movements of physical cash and non-cash inventory. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Sales" id="id-d13b8664642847efb4f6bcdc9bd1e999">
        <documentation>Covers all aspects of sales planning, campaign execution prospect and opportunity management, product matching and offer processing, including product specialist sales support and commission handling. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Cross Channel" id="id-d34bb4f27ccd440998b168e3ac3b55d0">
        <documentation>Contains the collection of Service Domains that handle the customer interaction across all possible channels, including customer identity authentication and activity authorization. It supports multiple session/device contacts and enables the leverage of the customer interaction and the build-up and analysis of access history. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="IT Management" id="id-dbb62a7ba65246cfb7c3da071b0a5cfc">
        <documentation>Includes the wide range of IT system operation, development and deployment activities for all production platforms, applications and communications technologies. This includes end user technology and help desk first and second level activities. It also includes the selection and definition of technology plans, policies, guidelines and standards and overall IT financial management and administration.&#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Investment Management" id="id-dbfb5672a4a54c19ae3e0db1ce93df17">
        <documentation>Handles investment activity, covering the managed investment portfolios with associated policies and valuation services and self-executed eTrading. </documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Trade &amp; Working Capital Solutions" id="id-dd0b8c58362e4130af288e6362b3d981"/>
      <element xsi:type="archimate:Capability" name="TWC Transactors" id="id-dd11a54e116f4f55b7de5bfbc667e7a0"/>
      <element xsi:type="archimate:Capability" name="Servicing" id="id-df115e3006bf4d46822415d1e439b7bb">
        <documentation>Brings together the fulfillment capabilities for various customer servicing support functions in particular customer case resolution and analysis and customer orders (customer related actions that span product and services). &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Knowledge and Intellectual Property" id="id-e3529b078caa4e688d362fce6af7fa53">
        <documentation>Supports the banks management and leverage of its intellectual property (IP) assets. This includes the registration/capture of IP, the administration and licensing of IP and infringement detection and responses when necessary.&#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Interaction Management" id="id-e996f24024fa4e0cac207fb891b0fb7b"/>
      <element xsi:type="archimate:Capability" name="Initiative Management" id="id-f293ebcd021b4f3990dba14a5010d58f"/>
      <element xsi:type="archimate:Capability" name="Regulations and Compliance" id="id-f35e9596e04b4aff956eb3011f58655f">
        <documentation>Covers the interpretation support, compliance assurance and regulatory reporting obligations of the bank, including ad-hoc compliance resolution when necessary. Note that general relations with the regulatory authorities are handled at an enterprise level elsewhere in the landscape. &#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Models" id="id-fbb68213b7224754939381291a2de776">
        <documentation>Covers the development, certification (where necessary) and deployment of a wide range of models and algorithms that may be used across the bank. It includes market risk and valuation models, business and operational risk, employee and customer behavior analyses, credit decisioning and fraud scanners and detection.&#xD;
</documentation>
      </element>
      <element xsi:type="archimate:Capability" name="Account Verification Services" id="id-fd7103c47ca44df3b2b7bfd4f1b22896"/>
      <element xsi:type="archimate:Capability" name="Corporate Financing and Advisory Services" id="id-fe1ce747a69449af953fe21354ed07f5">
        <documentation>Covers the corporate finance and advisory services offered to corporate clients including corporate finance advice, IPOs, M&amp;A and private and public offerings. &#xD;
</documentation>
      </element>
    </folder>
    <folder name="Resources" id="id-7b6a46c85f0c4597ab653a7f71735547">
      <element xsi:type="archimate:Resource" name="Application Architects" id="id-092a0ffded8041bab0274bd1027812d0"/>
      <element xsi:type="archimate:Resource" name="Technology Architect" id="id-63a68e2429f04c2aa73449f471fc2ff0"/>
      <element xsi:type="archimate:Resource" name="Domain Architects" id="id-6df2be4d429246fab8616c7ef3a3a166"/>
      <element xsi:type="archimate:Resource" name="Information Management Team" id="id-813ff29cd9604c798b106ff8672fce18"/>
      <element xsi:type="archimate:Resource" name="Solutions Architect" id="id-89ff32f61ad64360b7a186bb971b6a41"/>
      <element xsi:type="archimate:Resource" name="Information Architect" id="id-b624fe42e1bf4ad4941c525e96fa6a7e"/>
      <element xsi:type="archimate:Resource" name="Enterprise Architect" id="id-c3786170f8ac4241926a82317b556ea1"/>
      <element xsi:type="archimate:Resource" name="Business Architects" id="id-e2f71342fa394a6c98a4a5c72c375178"/>
      <element xsi:type="archimate:Resource" name="Architecture Model (Archi)" id="id-fabb674b21ba48bcb1716892fce99e0d"/>
    </folder>
    <folder name="Courses of Action" id="id-c00ead239e5d43c3ba07c06f50800ed2">
      <element xsi:type="archimate:CourseOfAction" name="Simplified, streamlined and integrated end-to-end  client, product and channel onboarding in across products, each country and for MNCs" id="id-407b286ec0d54233846a86fc72b09cbe"/>
      <element xsi:type="archimate:CourseOfAction" name="Identify Core existing clients/solutions" id="id-40d8d93e58de42dc90e57993fc367f89"/>
      <element xsi:type="archimate:CourseOfAction" name="Portfolio Reviews: Client behaviour in using Transact products" id="id-86834834530d41e8aee3aca2754dc0db"/>
      <element xsi:type="archimate:CourseOfAction" name="Use Sector Payments Pulse for transaction data analytics" id="id-9845b2c223d34b34a7d7786c91a1c396"/>
      <element xsi:type="archimate:CourseOfAction" name="AVS Programme" id="id-9b6d6e6c2e3347d794987b443faa63f3">
        <documentation>A key one we know about now is Account Verification Services which needs to be available via all the channels (UI, API, H2H) across the continent.&#xD;
AVS is 20 years old and it’s embedded into all client processes and especially needed for cross-border payments to automate, straight-through-process, and remove risks. </documentation>
      </element>
      <element xsi:type="archimate:CourseOfAction" name="Explore Nutron partnership for profile verification services, incl. credit, profile, proof of life and residence" id="id-9dadc7881ddf450d9778ba6aea351795"/>
      <element xsi:type="archimate:CourseOfAction" name="Real Time Payments - Urgent Pay" id="id-b5dc9c0e30fe45f1a2f17feef30e6848"/>
    </folder>
    <element xsi:type="archimate:Capability" name="In-Country Client Servicing Engagements" id="id-057d251abe2e44f6a0ee50a6526cb5a7"/>
    <element xsi:type="archimate:Capability" name="nav>> " id="id-06bbd2db79ae495aa01cca6a57bc83b8"/>
